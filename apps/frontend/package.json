{
  "name": "polly-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@navikt/aksel-icons": "8.9.0",
    "@navikt/ds-css": "8.9.0",
    "@navikt/ds-react": "8.9.0",
    "@navikt/ds-tailwind": "8.9.0",
    "@tailwindcss/postcss": "4.2.2",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "axios": "1.14.0",
    "core-js": "3.49.0",
    "flag-icon-css": "4.1.7",
    "formik": "2.4.9",
    "husky": "9.1.7",
    "json-diff-kit": "1.0.35",
    "lint-staged": "16.4.0",
    "lodash": "4.18.1",
    "moment": "2.30.1",
    "next": "16.2.3",
    "query-string": "9.3.1",
    "randomcolor": "0.6.2",
    "react": "19.2.4",
    "react-diff-viewer": "3.1.1",
    "react-dom": "19.2.4",
    "react-json-view": "1.21.3",
    "react-json-view-lite": "2.5.0",
    "react-localization": "2.0.6",
    "react-markdown": "10.1.0",
    "react-process-string": "1.2.0",
    "react-select": "5.10.2",
    "rehype-raw": "7.0.0",
    "remark-gfm": "4.0.1",
    "shortid": "2.2.17",
    "typescript": "6.0.2",
    "xlsx": "0.18.5",
    "yup": "1.7.1"
  },
  "scripts": {
    "start": "next dev",
    "build": "next build",
    "serve": "next start",
    "test": "jest",
    "format": "prettier --write \"./src\"",
    "prettier": "prettier --write \"./src\"",
    "prepare": "cd ../../ && husky apps/frontend/.husky",
    "type-check": "tsc --project tsconfig.json"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --list-different --write",
      "eslint --max-warnings 0"
    ],
    "*.{ts,tsx}": [
      "node -e \"require('child_process').execSync('yarn -s type-check', { stdio: 'inherit' })\""
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version",
      "ie 11"
    ]
  },
  "devDependencies": {
    "@eslint/compat": "2.0.4",
    "@types/lodash": "4.17.24",
    "@types/node": "25.5.2",
    "@types/randomcolor": "0.5.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/shortid": "2.2.0",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.1",
    "autoprefixer": "10.4.27",
    "encoding": "0.1.13",
    "eslint": "10.2.0",
    "eslint-config-next": "16.2.2",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "jest-fixed-jsdom": "0.0.11",
    "jest-watch-typeahead": "3.0.1",
    "node-fetch": "3.3.2",
    "postcss": "8.5.9",
    "postcss-import": "16.1.1",
    "prettier": "3.8.1",
    "tailwindcss": "4.2.2",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2"
  }
}
